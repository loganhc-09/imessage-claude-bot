# iMessage Bot Configuration

# Your Apple ID (the email you use for iMessage)
APPLE_ID=you@icloud.com

# Your phone number (iMessage may route self-texts through phone # too)
# Include country code, e.g. +15551234567
PHONE_NUMBER=

# Workspace directory — where Claude Code runs from
# This is where CLAUDE.md lives if you want to give Claude persistent context
CLAUDE_WORKSPACE=/path/to/your/workspace

# Path to Claude CLI binary
CLAUDE_PATH=/usr/local/bin/claude

# How often to check for new messages (seconds)
POLL_INTERVAL=3
