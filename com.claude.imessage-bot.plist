<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  launchd plist for iMessage Claude Bot.

  Install:
    1. Edit the paths below to match your setup
    2. Copy to ~/Library/LaunchAgents/
    3. launchctl load ~/Library/LaunchAgents/com.claude.imessage-bot.plist

  Logs: tail -f /tmp/imessage-bot.log
-->
<dict>
    <key>Label</key>
    <string>com.claude.imessage-bot</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <!-- EDIT THIS PATH to where you cloned the repo -->
        <string>/path/to/imessage-claude-bot/imessage-bot.py</string>
    </array>

    <key>WorkingDirectory</key>
    <!-- EDIT THIS PATH to where you cloned the repo -->
    <string>/path/to/imessage-claude-bot</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/tmp/imessage-bot.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/imessage-bot.error.log</string>
</dict>
</plist>
